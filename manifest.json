{
	"manifest_version": 3,
	"name": "Fuzzy Page Search",
	"version": "1.0",
	"description": "Fuzzy, deduplicated, keyboard-navigable search for any page.",
	"permissions": ["storage", "activeTab"],
	"host_permissions": ["<all_urls>"],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["src/content-script.ts"],
			"run_at": "document_end"
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_title": "Fuzzy Page Search"
	},
	"options_page": "options.html",
	"icons": {
		"128": "icon.png"
	}
}
